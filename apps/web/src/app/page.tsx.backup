                    <div className="w-16 h-16 mx-auto mb-6 bg-gray-100 rounded-lg flex items-center justify-center">
                      <Icon size={32} weight="bold" className="text-gray-900" />
                    </div>
                    <h3 className="text-lg font-semibold text-gray-900 mb-3">
                      {feature.title}
                    </h3>
                    <p className="text-sm text-gray-600 leading-relaxed">
                      {feature.description}
                    </p>
                  </div>
                );
              })}
            </div>
          </Container>
        </section>
        
        {/* Vehicle Categories Section */}
        <section className="py-20 md:py-32 bg-gray-50">
          <Container size="lg">
            <div className="max-w-3xl mx-auto text-center mb-16">
              <h2 className="text-3xl md:text-5xl font-semibold text-gray-900 mb-6">
                Vehicle Categories
              </h2>
              <p className="text-lg text-gray-600">
                Find the perfect vehicle for your needs.
              </p>
            </div>
            
            <div className="grid md:grid-cols-3 gap-8">
              {/* Exotic & Premium */}
              <div className="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-md transition-shadow">
                <div className="w-12 h-12 mb-6 bg-blue-100 rounded-lg flex items-center justify-center">
                  <Car size={24} weight="bold" className="text-blue-600" />
                </div>
                <h3 className="text-xl font-semibold text-gray-900 mb-3">
                  Exotic & Premium
                </h3>
                <p className="text-sm text-gray-600 mb-6">
                  Luxury sedans, SUVs, and exotic vehicles for special occasions and business travel.
                </p>
                <Link href="/listings?category=exotic">
                  <Button variant="ghost" size="sm">
                    Browse →
                  </Button>
                </Link>
              </div>
              
              {/* Eco-Gig */}
              <div className="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-md transition-shadow">
                <div className="w-12 h-12 mb-6 bg-green-100 rounded-lg flex items-center justify-center">
                  <Lightning size={24} weight="bold" className="text-green-600" />
                </div>
                <h3 className="text-xl font-semibold text-gray-900 mb-3">
                  Eco-Gig Vehicles
                </h3>
                <p className="text-sm text-gray-600 mb-6">
                  Fuel-efficient and electric vehicles perfect for ride-hailing and delivery services.
                </p>
                <Link href="/driver/gig-vehicles">
                  <Button variant="ghost" size="sm">
                    Browse →
                  </Button>
                </Link>
              </div>
              
              {/* Heavy-Haul */}
              <div className="bg-white border border-gray-200 rounded-lg p-8 hover:shadow-md transition-shadow">
                <div className="w-12 h-12 mb-6 bg-orange-100 rounded-lg flex items-center justify-center">
                  <Truck size={24} weight="bold" className="text-orange-600" />
                </div>
                <h3 className="text-xl font-semibold text-gray-900 mb-3">
                  Heavy-Haul
                </h3>
                <p className="text-sm text-gray-600 mb-6">
                  Trucks and logistics vehicles for transportation and hauling operations.
                </p>
                <Link href="/hauling">
                  <Button variant="ghost" size="sm">
                    Browse →
                  </Button>
                </Link>
              </div>
            </div>
          </Container>
        </section>
        
        {/* Trust Section */}
        <section className="py-20 md:py-32">
          <Container size="lg">
            <div className="max-w-3xl mx-auto">
              <div className="text-center mb-12">
                <h2 className="text-3xl md:text-5xl font-semibold text-gray-900 mb-6">
                  Built on Trust
                </h2>
                <p className="text-lg text-gray-600">
                  Every vehicle and lister is verified for your peace of mind.
                </p>
              </div>
              
              <div className="grid md:grid-cols-2 gap-6">
                <div className="flex items-start gap-4">
                  <CheckCircle size={24} weight="fill" className="text-green-600 flex-shrink-0 mt-1" />
                  <div>
                    <h3 className="font-semibold text-gray-900 mb-2">
                      Verified Listers
                    </h3>
                    <p className="text-sm text-gray-600">
                      All vehicle owners undergo identity verification and background checks.
                    </p>
                  </div>
                </div>
                
                <div className="flex items-start gap-4">
                  <CheckCircle size={24} weight="fill" className="text-green-600 flex-shrink-0 mt-1" />
                  <div>
                    <h3 className="font-semibold text-gray-900 mb-2">
                      Inspected Vehicles
                    </h3>
                    <p className="text-sm text-gray-600">
                      Every vehicle is inspected and insured before listing on the platform.
                    </p>
                  </div>
                </div>
                
                <div className="flex items-start gap-4">
                  <CheckCircle size={24} weight="fill" className="text-green-600 flex-shrink-0 mt-1" />
                  <div>
                    <h3 className="font-semibold text-gray-900 mb-2">
                      Real-Time Tracking
                    </h3>
                    <p className="text-sm text-gray-600">
                      IoT-enabled tracking ensures vehicle security and location monitoring.
                    </p>
                  </div>
                </div>
                
                <div className="flex items-start gap-4">
                  <CheckCircle size={24} weight="fill" className="text-green-600 flex-shrink-0 mt-1" />
                  <div>
                    <h3 className="font-semibold text-gray-900 mb-2">
                      24/7 Support
                    </h3>
                    <p className="text-sm text-gray-600">
                      Our support team is available around the clock to assist you.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </Container>
        </section>
        
        {/* CTA Section */}
        <section className="py-20 md:py-32 bg-gray-900">
          <Container size="lg">
            <div className="max-w-3xl mx-auto text-center">
              <h2 className="text-3xl md:text-5xl font-semibold text-white mb-6">
                Ready to Get Started?
              </h2>
              <p className="text-lg text-gray-400 mb-12">
                Choose your role and start accessing vehicles across Africa today.
              </p>
              <Button
