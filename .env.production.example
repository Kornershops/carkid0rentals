# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=carkid0_rentals
DATABASE_URL=host=postgres user=admin password=CHANGE_ME_STRONG_PASSWORD dbname=carkid0_rentals port=5432 sslmode=disable

# JWT Configuration
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_KEY_MIN_32_CHARS

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_live_YOUR_PAYSTACK_SECRET_KEY

# Frontend URL
FRONTEND_URL=https://your-domain.netlify.app

# Redis
REDIS_URL=redis:6379

# MQTT
MQTT_BROKER=tcp://emqx:1883

# NATS
NATS_URL=nats://nats:4222

# API URL (for frontend)
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1

# SmileID / Dojah (KYC)
SMILEID_API_KEY=your_smileid_api_key
SMILEID_PARTNER_ID=your_partner_id

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Monitoring (optional)
SENTRY_DSN=your_sentry_dsn
